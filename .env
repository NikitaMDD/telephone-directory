# ==========================================
# Application
# ==========================================

NODE_ENV=development

# ==========================================
# Backend
# ==========================================

BACKEND_PORT=3000

JWT_SECRET=super-secret-jwt-key

# ==========================================
# Frontend
# ==========================================

FRONTEND_PORT=5173

# ==========================================
# PostgreSQL
# ==========================================

POSTGRES_DB=telephone_directory

POSTGRES_USER=postgres

POSTGRES_PASSWORD=postgres

POSTGRES_PORT=5432

DATABASE_URL=postgresql://postgres:postgres@db:5432/telephone_directory

# ==========================================
# Nginx
# ==========================================

NGINX_PORT=80